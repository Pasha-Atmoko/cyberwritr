# Cyberwritr configuration — copy to .env and fill in, or export these in your shell.

# --- LLM backend: Moonshot / Kimi (OpenAI-compatible) ---
# Model routed through LiteLLM. Because LLM_API_BASE is set below, Cyberwritr
# uses the chat-completions API with JSON function tools (correct for Kimi).
CWRITR_LLM=openai/kimi-k2.5
LLM_API_BASE=https://api.moonshot.ai/v1
LLM_API_KEY=sk-your-moonshot-key-here

# Alternative Kimi models:
#   openai/kimi-k2-thinking     # heavier reasoning
#   openai/kimi-k2-0905         # 256K context

# --- Optional ---
# CWRITR_REASONING_EFFORT=high   # ignored by Kimi (LiteLLM drop_params handles it)
# CWRITR_TELEMETRY=false         # telemetry is OFF by default in this build
# PERPLEXITY_API_KEY=            # optional, for the web_search tool
